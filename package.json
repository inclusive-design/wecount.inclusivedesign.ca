{
  "name": "@wecount/wecount.inclusivedesign.ca",
  "version": "2026.4.1",
  "description": "The source files for the We Count website, built with Eleventy.",
  "license": "BSD-3-Clause",
  "author": "OCAD University <idrc@ocadu.ca>",
  "contributors": [
    "Cindy Li <cli@ocadu.ca> (https://github.com/cindyli)",
    "Gregor Moss <gmoss@ocadu.ca> (https://github.com/blueslug)",
    "Justin Obara <jobara@ocadu.ca> (https://github.com/jobara)",
    "Ted Thompson <tthompson@ocadu.ca> (https://github.com/TeddTech)",
    "Ned Zimmerman <nzimmerman@ocadu.ca> (https://github.com/greatislander)"
  ],
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm-run-all -l clean -p build:*",
    "build:eleventy": "cross-env NODE_ENV=production eleventy",
    "build:cms": "esbuild src/admin/cms.js --bundle --minify --outfile=_site/admin/cms.js",
    "clean": "rimraf _site",
    "start": "npm-run-all -l clean -p start:*",
    "start:cms": "esbuild src/admin/cms.js --watch --bundle --outfile=_site/admin/cms.js",
    "start:eleventy": "eleventy --incremental --serve",
    "serve": "npx serve _site",
    "lint": "run-s -l lint:*",
    "lint:stylelint": "stylelint \"**/*.css\"",
    "lint:eslint": "eslint",
    "lint:markdownlint": "markdownlint-cli2 \"**/*.md\"",
    "prepare": "husky",
    "test": "run-s test:*",
    "test:commitlint": "echo 'fix: make sure commitlint works' | npx --no-install commitlint --config commitlint.config.mjs"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "axios": "^1.15.0",
    "eleventy-plugin-fluid": "^3.2.1",
    "infusion": "^4.8.0",
    "linkedom": "^0.18.12",
    "lite-youtube-embed": "^0.3.4",
    "modern-css-reset": "^1.4.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@inclusive-design/eslint-config": "^0.5.0",
    "@inclusive-design/markdownlint-config": "^0.1.1",
    "@inclusive-design/stylelint-config": "^0.1.0",
    "autoprefixer": "^10.4.23",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "markdownlint-cli2": "^0.22.0",
    "npm-run-all2": "^8.0.4",
    "rimraf": "^6.1.2",
    "stylelint": "^17.7.0"
  },
  "lint-staged": {
    "*.css": "stylelint --fix",
    "*.{cjs,js,json,mjs}": [
      "eslint --fix"
    ],
    "*.md": [
      "eslint --fix",
      "markdownlint-cli2 --fix"
    ]
  }
}
